</style>

<script>
  const root = document.documentElement;

  const themeToggle = document.getElementById("theme-toggle")!;
  const savedTheme = localStorage.getItem("theme");
  if (savedTheme === "dark") {
    root.setAttribute("data-theme", "dark");
    themeToggle.textContent = "☀";
  }
  themeToggle.addEventListener("click", () => {
    const isDark = root.getAttribute("data-theme") === "dark";
    if (isDark) {
      root.removeAttribute("data-theme");
      themeToggle.textContent = "☾";
      localStorage.setItem("theme", "light");
    } else {
      root.setAttribute("data-theme", "dark");
      themeToggle.textContent = "☀";
      localStorage.setItem("theme", "dark");
    }
  });

  const langToggle = document.getElementById("lang-toggle")!;
  const searchInput = document.getElementById(
    "search-input",
  ) as HTMLInputElement;
  function applyLang(lang: string) {
    root.setAttribute("data-lang", lang);
    langToggle.textContent = lang === "vi" ? "VI" : "EN";
    const key =
      lang === "vi" ? "data-i18n-placeholder-vi" : "data-i18n-placeholder-en";
    const placeholder = searchInput.getAttribute(key);
    if (placeholder) searchInput.setAttribute("placeholder", placeholder);
  }
  const savedLang = localStorage.getItem("lang");
  if (savedLang === "en") applyLang("en");
  langToggle.addEventListener("click", () => {
    const next = root.getAttribute("data-lang") === "vi" ? "en" : "vi";
    applyLang(next);
    localStorage.setItem("lang", next);
  });

  function filterList(
    input: string,
    items: NodeListOf<HTMLElement>,
    emptyEl: HTMLElement | null,
  ) {
    const q = input.trim().toLowerCase();
    let visible = 0;
    items.forEach((el) => {
      const match = !q || (el.dataset.filter || "").includes(q);
      el.style.display = match ? "" : "none";
      if (match) visible++;
    });
    if (emptyEl) emptyEl.hidden = visible !== 0;
  }
  const socialItems = document.querySelectorAll<HTMLElement>(".social-item");
  const productItems = document.querySelectorAll<HTMLElement>(".product-card");
  const socialEmpty = document.querySelector<HTMLElement>(
    '[data-role="social-empty"]',
  );
  const productsEmpty = document.querySelector<HTMLElement>(
    '[data-role="products-empty"]',
  );
  searchInput.addEventListener("input", () => {
    filterList(searchInput.value, socialItems, socialEmpty);
    filterList(searchInput.value, productItems, productsEmpty);
  });

  const revealEls = document.querySelectorAll<HTMLElement>("[data-reveal]");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
          if (entry.target.getAttribute("data-reveal") === "journey")
            startJourneyLoop();
        }
      });
    },
    { threshold: 0.15, rootMargin: "0px 0px -10% 0px" },
  );
  revealEls.forEach((el) => observer.observe(el));

  const journeySteps = document.querySelectorAll<HTMLElement>(".journey-step");
  const journeyRunner = document.getElementById("journey-runner");
  const journeyTrack = document.getElementById("journey-track");
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;
  function setActiveStep(i: number, jump = false) {
    journeySteps.forEach((el, idx) =>
      el.classList.toggle("is-active", idx === i),
    );
    if (journeyRunner) {
      if (jump) journeyRunner.style.transition = "none";
      const pct = ((i + 0.5) / journeySteps.length) * 100;
      journeyRunner.style.left = `calc(${pct.toFixed(2)}% - 7px)`;
      if (jump) {
        void journeyRunner.offsetHeight;
        journeyRunner.style.transition = "";
      }
    }
    const track = journeyTrack;
    const stepEl = journeySteps[i];
    if (track && stepEl && track.scrollWidth > track.clientWidth) {
      const target = jump
        ? 0
        : stepEl.offsetLeft + stepEl.clientWidth / 2 - track.clientWidth / 2;
      track.scrollTo({
        left: Math.max(0, target),
        behavior: jump ? "instant" : "smooth",
      });
    }
  }
  function startJourneyLoop() {
    if (prefersReducedMotion || journeySteps.length === 0) {
      setActiveStep(0);
      return;
    }
    let i = 0;
    const tick = (jump = false) => {
      setActiveStep(i, jump);
      setTimeout(() => {
        const next = (i + 1) % journeySteps.length;
        const wrapped = next === 0;
        i = next;
        tick(wrapped);
      }, 1400);
    };
    tick(false);
  }

  const backToTop = document.getElementById("back-to-top")!;
  window.addEventListener(
    "scroll",
    () => {
      backToTop.hidden = window.scrollY <= 400;
    },
    { passive: true },
  );
  backToTop.addEventListener("click", () =>
    window.scrollTo({ top: 0, behavior: "smooth" }),
  );
</script>
