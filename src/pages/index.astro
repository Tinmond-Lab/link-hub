---
import {
  siYoutube,
  siTiktok,
  siFacebook,
  siShopee,
  siZalo,
} from "simple-icons";
import iconCode from "lucide-static/icons/code.svg?raw";
import iconCuboid from "lucide-static/icons/cuboid.svg?raw";
import iconPaintbrush from "lucide-static/icons/paintbrush.svg?raw";
import iconLayers from "lucide-static/icons/layers.svg?raw";

const socials = [
  {
    name: "YouTube",
    handle: "@timondlab",
    href: "https://youtube.com/@timondlab",
    color: `#${siYoutube.hex}`,
    path: siYoutube.path,
  },
  {
    name: "TikTok",
    handle: "@timondlab",
    href: "https://tiktok.com/@timondlab",
    color: "var(--text)",
    path: siTiktok.path,
  },
  {
    name: "Facebook",
    handle: "@timondlab",
    href: "https://facebook.com/timondlab",
    color: `#${siFacebook.hex}`,
    path: siFacebook.path,
  },
  {
    name: "Shopee",
    handle: "@timondlab",
    href: "https://shopee.vn/timondlab",
    color: `#${siShopee.hex}`,
    path: siShopee.path,
  },
  {
    name: "Zalo",
    handle: "@timondlab",
    href: "https://zalo.me/timondlab",
    color: `#${siZalo.hex}`,
    path: siZalo.path,
  },
  {
    name: "Email",
    handle: "hello@timondlab.com",
    href: "mailto:hello@timondlab.com",
    color: "var(--accent)",
    path: null,
  },
];

const products = [
  {
    slotId: "prod-thap",
    name: "Tháp Nghinh Phong",
    descVi:
      "Diorama kiến trúc chi tiết, tái hiện công trình biểu tượng Đà Lạt.",
    descEn:
      "Detailed architectural diorama recreating a landmark Đà Lạt tower.",
  },
  {
    slotId: "prod-diorama",
    name: "Miniature Diorama",
    descVi:
      "Bối cảnh thu nhỏ kể chuyện, kết hợp ánh sáng và chi tiết thủ công.",
    descEn: "Storytelling miniature scenes with hand-detailing and lighting.",
  },
  {
    slotId: "prod-figure",
    name: "Resin Figure",
    descVi: "Figure resin sơn tay, giới hạn số lượng theo từng đợt.",
    descEn: "Hand-painted resin figures, released in limited batches.",
  },
  {
    slotId: "prod-soon",
    name: "Coming Soon",
    descVi: "Dự án tiếp theo đang được phát triển — theo dõi để cập nhật.",
    descEn: "Next project in development — stay tuned for updates.",
  },
];

const journeySteps = [
  { vi: "Ý tưởng", en: "Idea" },
  { vi: "Dựng 3D", en: "3D Modeling" },
  { vi: "In 3D", en: "Printing" },
  { vi: "Sơn vẽ", en: "Painting" },
  { vi: "Đóng gói", en: "Packaging" },
  { vi: "Vận chuyển", en: "Shipping" },
];

const buildPublic = [
  { slotId: "bip-0", vi: "Video mới nhất", en: "Latest Video" },
  { slotId: "bip-1", vi: "Dự án đang làm", en: "Current Build" },
  { slotId: "bip-2", vi: "Hậu trường", en: "Behind the Scenes" },
];

const services = [
  { vi: "Phát triển phần mềm", en: "Software Development", svg: iconCode },
  { vi: "Mô hình theo yêu cầu", en: "Custom Miniatures", svg: iconCuboid },
  { vi: "Sơn figure", en: "Figure Painting", svg: iconPaintbrush },
  { vi: "Thiết kế diorama", en: "Diorama Design", svg: iconLayers },
];

const values = [
  { vi: "Chất lượng hàng đầu", en: "Quality First" },
  { vi: "Thủ công tỉ mỉ", en: "Handcrafted" },
  { vi: "Chú trọng chi tiết", en: "Attention to Detail" },
  { vi: "Học hỏi không ngừng", en: "Continuous Learning" },
  { vi: "Khách hàng là trọng tâm", en: "Customer First" },
  { vi: "Sáng tạo", en: "Creativity" },
];

const faq = [
  {
    qVi: "Bạn sử dụng chất liệu gì?",
    qEn: "What materials do you use?",
    aVi: "Chủ yếu là nhựa resin cao cấp, nhựa in 3D và sơn chuyên dụng cho mô hình, được lựa chọn kỹ để đảm bảo độ bền và chi tiết.",
    aEn: "Mainly premium resin, 3D-printed filament/resin, and dedicated miniature paints, chosen for durability and fine detail.",
  },
  {
    qVi: "Sản phẩm được làm như thế nào?",
    qEn: "How are products made?",
    aVi: "Mỗi sản phẩm trải qua quy trình: lên ý tưởng, dựng mô hình 3D, in 3D, đổ resin, sơn tay và đóng gói thủ công.",
    aEn: "Each piece goes through: idea, 3D modeling, 3D printing, resin casting, hand painting and packaging.",
  },
  {
    qVi: "Tôi có thể đặt làm theo yêu cầu không?",
    qEn: "Can I order custom work?",
    aVi: "Có. Timond Lab nhận thực hiện các dự án custom theo ý tưởng riêng của bạn, từ figure đến diorama.",
    aEn: "Yes — Timond Lab takes on custom projects, from figures to full dioramas, built around your idea.",
  },
  {
    qVi: "Có giao hàng quốc tế không?",
    qEn: "Do you ship internationally?",
    aVi: "Có, Timond Lab hỗ trợ giao hàng quốc tế cho một số sản phẩm và đơn custom.",
    aEn: "Yes, international shipping is available for select products and custom orders.",
  },
];
---

<html lang="vi" data-lang="vi">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Timond Lab — studio sáng tạo kết hợp phát triển phần mềm với nghệ thuật mô hình thủ công."
    />
    <title>Timond Lab · LinkHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="topbar">
      <div class="search-box">
        <span class="search-icon">⌕</span>
        <input
          id="search-input"
          class="search-input"
          type="text"
          data-i18n-placeholder-vi="Tìm liên kết, sản phẩm..."
          data-i18n-placeholder-en="Search links, products..."
          placeholder="Tìm liên kết, sản phẩm..."
        />
      </div>
      <div class="topbar-actions">
        <button
          id="lang-toggle"
          class="pill-btn"
          type="button"
          aria-label="Toggle language">VI</button
        >
        <button
          id="theme-toggle"
          class="pill-btn icon-btn"
          type="button"
          aria-label="Toggle theme">☾</button
        >
      </div>
    </div>

    <div class="container">
      <section class="hero" data-screen-label="Hero">
        <div class="hero-avatar-wrap">
          <div class="hero-avatar">
            <img
              src="/avatar.webp"
              alt="Timond Lab avatar"
              width="128"
              height="128"
            />
          </div>
        </div>
        <div class="hero-brand">Timond Lab</div>
        <h1 class="hero-title">Build Ideas Into Reality</h1>
        <div class="hero-subtitle">
          <span data-i18n="vi"
            >Lập trình viên phần mềm • Nghệ sĩ Resin • Nhà sáng tạo Diorama •
            Họa sĩ tô mô hình</span
          >
          <span data-i18n="en"
            >Software Developer • Resin Artist • Diorama Creator • Figure
            Painter</span
          >
        </div>
        <div class="hero-ctas">
          <a href="#products" class="btn btn-primary">
            <span data-i18n="vi">Khám phá sản phẩm</span>
            <span data-i18n="en">Explore Products</span>
          </a>
          <a href="#journey" class="btn btn-secondary">
            <span data-i18n="vi">Xem hành trình</span>
            <span data-i18n="en">Watch My Journey</span>
          </a>
          <a href="#social" class="btn btn-secondary">
            <span data-i18n="vi">Liên hệ</span>
            <span data-i18n="en">Contact Me</span>
          </a>
        </div>
      </section>

      <section
        class="section reveal"
        data-reveal="about"
        data-screen-label="About"
      >
        <div class="about-card">
          <div class="eyebrow">
            <span data-i18n="vi">Về Timond Lab</span>
            <span data-i18n="en">About Timond Lab</span>
          </div>
          <div class="about-body">
            <p data-i18n="vi">
              Timond Lab là studio sáng tạo kết hợp phát triển phần mềm với nghệ
              thuật mô hình thủ công — nơi công nghệ và thủ công gặp nhau để tạo
              ra những sản phẩm độc bản, cùng câu chuyện phía sau từng ý tưởng:
              từ concept, in 3D, đổ resin, sơn vẽ, đóng gói đến phát triển phần
              mềm.
            </p>
            <p data-i18n="en">
              Timond Lab is a creative studio blending software development with
              handcrafted miniature art — where technology and craftsmanship
              meet to build unique products, sharing every step of the journey:
              concept, 3D printing, resin casting, painting, packaging and
              software development.
            </p>
          </div>
        </div>
      </section>

      <section
        id="social"
        class="section reveal"
        data-reveal="social"
        data-screen-label="Social Links"
      >
        <h2 class="section-title">
          <span data-i18n="vi">Kết nối với Timond Lab</span>
          <span data-i18n="en">Connect with Timond Lab</span>
        </h2>
        <div class="social-list">
          {
            socials.map((s, i) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                class="social-item"
                data-filter={`${s.name} ${s.handle}`.toLowerCase()}
                style={`--i:${i}`}
              >
                <div
                  class="social-icon"
                  style={`background:color-mix(in srgb, ${s.color} 12%, transparent)`}
                >
                  {s.path ? (
                    <svg
                      viewBox="0 0 24 24"
                      width="18"
                      height="18"
                      fill={s.color}
                    >
                      <path d={s.path} />
                    </svg>
                  ) : (
                    <svg
                      viewBox="0 0 24 24"
                      width="20"
                      height="20"
                      fill="none"
                      stroke={s.color}
                      stroke-width="2"
                      stroke-linejoin="round"
                      stroke-linecap="round"
                    >
                      <rect x="3" y="5" width="18" height="14" rx="2" />
                      <path d="M4 7l8 6 8-6" />
                    </svg>
                  )}
                </div>
                <div class="social-text">
                  <div class="social-name">{s.name}</div>
                  <div class="social-handle">{s.handle}</div>
                </div>
                <div class="social-chevron">›</div>
              </a>
            ))
          }
        </div>
        <p class="no-results" data-role="social-empty" hidden>
          <span data-i18n="vi">Không tìm thấy kết quả phù hợp.</span>
          <span data-i18n="en">No matching results.</span>
        </p>
      </section>

      <section
        id="products"
        class="section reveal"
        data-reveal="products"
        data-screen-label="Products"
      >
        <h2 class="section-title">
          <span data-i18n="vi">Bộ sưu tập nổi bật</span>
          <span data-i18n="en">Featured Collections</span>
        </h2>
        <div class="products-grid">
          {
            products.map((p, i) => (
              <div
                class="product-card"
                data-filter={p.name.toLowerCase()}
                style={`--i:${i}`}
              >
                <div class="product-image placeholder" data-slot={p.slotId}>
                  <span class="placeholder-icon" aria-hidden="true">
                    🖼
                  </span>
                  <span class="placeholder-label">{p.name}</span>
                </div>
                <div class="product-body">
                  <div class="product-name">{p.name}</div>
                  <div class="product-desc">
                    <span data-i18n="vi">{p.descVi}</span>
                    <span data-i18n="en">{p.descEn}</span>
                  </div>
                  <a href="#" class="product-link">
                    <span data-i18n="vi">Xem chi tiết</span>
                    <span data-i18n="en">View Details</span>
                  </a>
                </div>
              </div>
            ))
          }
        </div>
        <p class="no-results" data-role="products-empty" hidden>
          <span data-i18n="vi">Không tìm thấy kết quả phù hợp.</span>
          <span data-i18n="en">No matching results.</span>
        </p>
      </section>

      <section
        id="journey"
        class="section reveal"
        data-reveal="journey"
        data-screen-label="Journey"
      >
        <h2 class="section-title">
          <span data-i18n="vi">Hành trình tạo tác phẩm</span>
          <span data-i18n="en">The Making Journey</span>
        </h2>
        <div class="journey-wrap">
          <div id="journey-track" class="journey-track">
            <div id="journey-runner" class="journey-runner"></div>
            {
              journeySteps.map((step, i) => (
                <div class="journey-step" style={`--i:${i}`} data-step={i}>
                  {i < journeySteps.length - 1 && <div class="journey-line" />}
                  <div class="journey-badge">{i + 1}</div>
                  <div class="journey-label">
                    <span data-i18n="vi">{step.vi}</span>
                    <span data-i18n="en">{step.en}</span>
                  </div>
                </div>
              ))
            }
          </div>
          <div class="fade-edge fade-edge-left"></div>
          <div class="fade-edge fade-edge-right"></div>
        </div>
      </section>

      <section
        class="section reveal"
        data-reveal="buildpublic"
        data-screen-label="Build in Public"
      >
        <h2 class="section-title" style="margin-bottom:4px">
          <span data-i18n="vi">Build in Public</span>
          <span data-i18n="en">Build in Public</span>
        </h2>
        <div class="section-sub">
          <span data-i18n="vi"
            >Dự án mới nhất, hậu trường & hành trình học hỏi</span
          >
          <span data-i18n="en"
            >Latest projects, behind the scenes & the learning journey</span
          >
        </div>
        <div class="buildpublic-grid">
          {
            buildPublic.map((v, i) => (
              <div class="bip-card" style={`--i:${i}`}>
                <div class="bip-image placeholder" data-slot={v.slotId}>
                  <span class="placeholder-icon" aria-hidden="true">
                    🖼
                  </span>
                </div>
                <div class="bip-label">
                  <span data-i18n="vi">{v.vi}</span>
                  <span data-i18n="en">{v.en}</span>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section
        class="section reveal"
        data-reveal="services"
        data-screen-label="Services"
      >
        <h2 class="section-title">
          <span data-i18n="vi">Dịch vụ</span>
          <span data-i18n="en">Services</span>
        </h2>
        <div class="services-grid">
          {
            services.map((sv, i) => (
              <div class="service-card" style={`--i:${i}`}>
                <div class="service-icon" set:html={sv.svg} />
                <div class="service-label">
                  <span data-i18n="vi">{sv.vi}</span>
                  <span data-i18n="en">{sv.en}</span>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section
        class="section reveal"
        data-reveal="values"
        data-screen-label="Values"
      >
        <h2 class="section-title">
          <span data-i18n="vi">Giá trị cốt lõi</span>
          <span data-i18n="en">Values</span>
        </h2>
        <div class="values-grid">
          {
            values.map((val, i) => (
              <div class="value-item" style={`--i:${i}`}>
                <div class="value-check">
                  <svg
                    viewBox="0 0 24 24"
                    width="15"
                    height="15"
                    fill="none"
                    stroke="#fff"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="5,13 10,18 19,7" />
                  </svg>
                </div>
                <div class="value-label">
                  <span data-i18n="vi">{val.vi}</span>
                  <span data-i18n="en">{val.en}</span>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="section reveal" data-reveal="faq" data-screen-label="FAQ">
        <h2 class="section-title">
          <span data-i18n="vi">Câu hỏi thường gặp</span>
          <span data-i18n="en">FAQ</span>
        </h2>
        <div class="faq-list">
          {
            faq.map((item, i) => (
              <details class="faq-item" style={`--i:${i}`}>
                <summary class="faq-question">
                  <span class="faq-question-text">
                    <span data-i18n="vi">{item.qVi}</span>
                    <span data-i18n="en">{item.qEn}</span>
                  </span>
                  <span class="faq-icon" aria-hidden="true">
                    +
                  </span>
                </summary>
                <div class="faq-answer">
                  <span data-i18n="vi">{item.aVi}</span>
                  <span data-i18n="en">{item.aEn}</span>
                </div>
              </details>
            ))
          }
        </div>
      </section>
    </div>

    <div class="closing-wrap">
      <div class="closing-card">
        <div class="closing-title">
          <span data-i18n="vi">Sẵn sàng bắt đầu?</span>
          <span data-i18n="en">Ready to start?</span>
        </div>
        <div class="closing-sub">
          <span data-i18n="vi"
            >Liên hệ Timond Lab để đặt sản phẩm hoặc trao đổi ý tưởng của bạn.</span
          >
          <span data-i18n="en"
            >Reach out to Timond Lab to order a piece or talk through your idea.</span
          >
        </div>
        <a href="#social" class="btn btn-primary">
          <span data-i18n="vi">Liên hệ</span>
          <span data-i18n="en">Contact Me</span>
        </a>
      </div>
    </div>

    <footer class="footer">
      <div class="footer-name">Timond Lab</div>
      <div class="footer-tagline">Build Ideas Into Reality</div>
      <div class="footer-copy">
        © 2026 Timond Lab · Designed by Nguyễn Hoàng Tín
      </div>
    </footer>

    <button
      id="back-to-top"
      class="back-to-top"
      type="button"
      aria-label="Back to top"
      hidden>↑</button
    >
  </body>
</html>

<style>
  :root {
    --bg: #f5f7fa;
    --surface: #ffffff;
    --bar-bg: rgba(245, 247, 250, 0.8);
    --text: #0f172a;
    --muted: #64748b;
    --border: #e3e7ed;
    --accent: #1677ff;
    --chip: #eaf2ff;
  }
  :root[data-theme="dark"] {
    --bg: #0f172a;
    --surface: #182238;
    --bar-bg: rgba(15, 23, 42, 0.75);
    --text: #f5f7fa;
    --muted: #94a3b8;
    --border: rgba(217, 217, 217, 0.14);
    --accent: #4c9aff;
    --chip: rgba(76, 154, 255, 0.14);
  }

  * {
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    font-family:
      "Be Vietnam Pro",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: var(--bg);
    color: var(--text);
    transition:
      background 0.25s ease,
      color 0.25s ease;
  }
  ::selection {
    background: var(--accent);
    color: #fff;
  }
  a {
    color: inherit;
  }

  [data-i18n="en"] {
    display: none;
  }
  html[data-lang="en"] [data-i18n="en"] {
    display: unset;
  }
  html[data-lang="en"] [data-i18n="vi"] {
    display: none;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    gap: clamp(8px, 3vw, 16px);
    padding: 10px clamp(12px, 4vw, 24px);
    background: var(--bar-bg);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }
  .search-box {
    flex: 1;
    min-width: 0;
    max-width: 360px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 11px 14px;
    transition: border-color 0.2s ease;
  }
  .search-box:focus-within {
    border-color: var(--accent);
  }
  .search-icon {
    opacity: 0.5;
    font-size: 13px;
    flex-shrink: 0;
  }
  .search-input {
    border: none;
    outline: none;
    background: transparent;
    color: var(--text);
    font-size: 13px;
    width: 100%;
    min-width: 0;
    font-family: inherit;
  }
  .search-input::placeholder {
    color: inherit;
    opacity: 0.5;
  }
  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }
  .pill-btn {
    cursor: pointer;
    font: inherit;
    font-size: 12px;
    font-weight: 700;
    padding: 0 12px;
    height: 40px;
    min-width: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
